---
import BaseHead from "@/components/BaseHead.astro";
import SiteShell from "@/layouts/SiteShell.astro";
import ContributorsPage from "@/react-pages/contributors/ContributorsPage";
import { getAllOrganizations } from "@/data/organizations";
import { getAllPeople } from "@/data/people";
import { getCollection } from "astro:content";
import { isDraftVisible } from "@/utils/drafts";
import { toPersonCardData, toOrganizationCardData } from "@/utils/card-mappers";
import type {
  ContributorsPagePersonItem,
  ContributorsPageOrganizationItem,
  ContributorsPagePartnerSection,
} from "@semio-community/ecosystem-site-core";
import React from "react";
import { UsersGroupTwoRounded } from "@solar-icons/react-perf/LineDuotone";

const meta = {
  title: "Contributors",
  description:
    "People and organizations advancing human-centered robotics and AI together",
};
const ogImage = "/og/contributors.png";

const allOrganizations = await getAllOrganizations();
const allPeople = await getAllPeople();
const organizations = await getCollection("organizations", ({ data }) =>
  isDraftVisible(data.draft, data.sites),
);

const orgNameById = Object.fromEntries(
  organizations.map((org) => [org.id, org.data.shortName || org.data.name]),
);

function affiliationLabel(person: (typeof allPeople)[number]): string | undefined {
  const aff =
    person.data.affiliations?.find((a) => a.isPrimary) ??
    person.data.affiliations?.find((a) => !a.endDate);
  return aff ? orgNameById[aff.organizationId] || aff.organizationId : undefined;
}

const HIDE_BOARD_MEMBERS = true;
const boardMembers = allPeople.filter(
  (p) => p.data.isContributor && p.data.boardMember,
);
const communityMembers = allPeople.filter(
  (p) =>
    p.data.isContributor && (HIDE_BOARD_MEMBERS ? true : !p.data.boardMember),
);

const donorPeople = allPeople.filter((p) => p.data.isDonor);
const donorOrganizations = organizations.filter((org) => org.data.isDonor);
const grantMakers = organizations.filter((org) => org.data.isGrantMaker);

const partnerTypeInfo: Record<
  string,
  { title: string; icon: string; description: string }
> = {
  industry: {
    title: "Industry Partners",
    icon: "solar:buildings-2-line-duotone",
    description: "Companies driving innovation in robotics and AI",
  },
  nonprofit: {
    title: "Non-Profit Partners",
    icon: "solar:hand-shake-line-duotone",
    description: "Organizations advancing social impact through technology",
  },
  academic: {
    title: "Academic Partners",
    icon: "solar:square-academic-cap-line-duotone",
    description: "Leading universities and research institutions",
  },
  government: {
    title: "Government Partners",
    icon: "solar:flag-2-line-duotone",
    description: "Public sector organizations and agencies",
  },
};
const orderedPartnerTypes = ["industry", "nonprofit", "academic", "government"];

const partnersByType: Record<string, typeof allOrganizations> = {};
for (const partner of allOrganizations) {
  if (!partnersByType[partner.data.type]) {
    partnersByType[partner.data.type] = [];
  }
  partnersByType[partner.data.type]!.push(partner);
}

const mappedBoardMembers: ContributorsPagePersonItem[] = boardMembers.map((p) => ({
  id: p.id,
  data: toPersonCardData(p.data),
  affiliationLabel: affiliationLabel(p),
}));

const mappedCommunityMembers: ContributorsPagePersonItem[] = communityMembers.map((p) => ({
  id: p.id,
  data: toPersonCardData(p.data),
  affiliationLabel: affiliationLabel(p),
}));

const mappedPartnerSections: ContributorsPagePartnerSection[] = [
  ...orderedPartnerTypes,
  ...Object.keys(partnersByType).filter(
    (type) => !orderedPartnerTypes.includes(type),
  ),
].map((type) => ({
  type,
  info: partnerTypeInfo[type] ?? null,
  partners: (partnersByType[type] ?? []).map((o): ContributorsPageOrganizationItem => ({
    id: o.id,
    data: toOrganizationCardData(o.data),
  })),
}));

const mappedDonorPeople: ContributorsPagePersonItem[] = donorPeople.map((p) => ({
  id: p.id,
  data: toPersonCardData(p.data),
}));

const mappedDonorOrganizations: ContributorsPageOrganizationItem[] = donorOrganizations.map((o) => ({
  id: o.id,
  data: toOrganizationCardData(o.data),
}));

const mappedGrantMakers: ContributorsPageOrganizationItem[] = grantMakers.map((o) => ({
  id: o.id,
  data: toOrganizationCardData(o.data),
}));

const heroIcon = React.createElement(UsersGroupTwoRounded, { className: "w-16 h-16 text-accent-two" });
---

<html
  class="overflow-x-hidden grid scroll-pt-18 scroll-smooth font-sans text-text antialiased"
  lang="en"
>
  <head>
    <BaseHead
      title={meta.title}
      description={meta.description}
      ogImage={ogImage}
    />
  </head>
  <body class="relative min-h-screen w-full bg-surface text-xl md:text-base">
    <SiteShell showBackground containerClassName="max-w-6xl">
      <ContributorsPage
        meta={meta}
        hideBoardMembers={HIDE_BOARD_MEMBERS}
        boardMembers={mappedBoardMembers}
        communityMembers={mappedCommunityMembers}
        partnerSections={mappedPartnerSections}
        donorPeople={mappedDonorPeople}
        donorOrganizations={mappedDonorOrganizations}
        grantMakers={mappedGrantMakers}
        heroIcon={heroIcon}
        baseUrl={import.meta.env.BASE_URL}
      />
    </SiteShell>
  </body>
</html>
